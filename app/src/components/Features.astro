---
import type { PropertyData } from '../types/property';

interface Props {
  property: PropertyData;
}

const { property } = Astro.props;
const { features } = property;
---

<section class="features section" id="features" aria-label="Property features">
  <div class="container">
    <div class="features__header">
      <div>
        <span class="section-label">Features &amp; Finishes</span>
        <h2>Inside the Home</h2>
      </div>
    </div>

    <div class="features__grid">
      {features.map(category => (
        <div class="features__category">
          <h3 class="features__cat-title">{category.category}</h3>
          <ul class="features__list">
            {category.items.map(item => (
              <li class="features__item">{item}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style lang="scss">
  @use '../styles/variables' as *;

  .features {
    background: $color-bg-mid;

    &__header {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      margin-bottom: $space-lg;

      h2 {
        margin-top: 0.5rem;
        font-size: clamp(1.8rem, 3vw, 2.6rem);
      }
    }

    &__grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 1px;
      background: $color-border;
      border: 1px solid $color-border;
      border-radius: 2px;
      overflow: hidden;
    }

    &__category {
      background: #fff;
      padding: 2rem 2rem 2.25rem;
    }

    &__cat-title {
      font-family: $font-sans;
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: $color-accent;
      margin-bottom: 1.25rem;
      padding-bottom: 0.75rem;
      border-bottom: 1px solid $color-border;
    }

    &__list {
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    &__item {
      font-size: 0.88rem;
      color: $color-text;
      line-height: 1.5;
      padding: 0.5rem 0;
      border-bottom: 1px solid rgba($color-border, 0.6);
      display: flex;
      align-items: baseline;
      gap: 0.6rem;

      &:last-child {
        border-bottom: none;
        padding-bottom: 0;
      }

      &::before {
        content: '';
        display: block;
        width: 4px;
        height: 4px;
        border-radius: 50%;
        background: $color-accent;
        flex-shrink: 0;
        margin-top: 0.42em;
      }
    }
  }
</style>

---
import type { PropertyData } from '../types/property';
import type { SiteTemplateId } from '../templates/site';

interface Props {
  property: PropertyData;
  variant?: SiteTemplateId;
}

const { property, variant = 'classic' } = Astro.props;
const { features } = property;
---

<section class:list={['features section', variant === 'modern' && 'features--modern', variant === 'bold' && 'features--bold', variant === 'lifestyle' && 'features--lifestyle']} id="features" aria-label="Property features">
  <div class="container">
    <div class="features__header">
      <div>
        <span class="section-label">Features &amp; Finishes</span>
        <h2>{variant === 'modern' ? 'Scannable, room-by-room highlights' : variant === 'lifestyle' ? 'Comfort, function, and thoughtful details' : 'Inside the Home'}</h2>
      </div>
    </div>

    <div class="features__grid">
      {features.map(category => (
        <div class="features__category">
          <h3 class="features__cat-title">{category.category}</h3>
          <ul class="features__list">
            {category.items.map(item => (
              <li class="features__item">{item}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style lang="scss">
  @use '../styles/variables' as *;

  .features {
    background: $color-bg-mid;

    &__header {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      margin-bottom: $space-lg;

      h2 {
        margin-top: 0.5rem;
        font-size: clamp(1.8rem, 3vw, 2.6rem);
      }
    }

    &__grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 1px;
      background: $color-border;
      border: 1px solid $color-border;
      border-radius: 2px;
      overflow: hidden;
    }

    &__category {
      background: #fff;
      padding: 2rem 2rem 2.25rem;
    }

    &__cat-title {
      font-family: $font-sans;
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: $color-accent;
      margin-bottom: 1.25rem;
      padding-bottom: 0.75rem;
      border-bottom: 1px solid $color-border;
    }

    &__list {
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    &__item {
      font-size: 0.88rem;
      color: $color-text;
      line-height: 1.5;
      padding: 0.5rem 0;
      border-bottom: 1px solid rgba($color-border, 0.6);
      display: flex;
      align-items: baseline;
      gap: 0.6rem;

      &:last-child {
        border-bottom: none;
        padding-bottom: 0;
      }

      &::before {
        content: '';
        display: block;
        width: 4px;
        height: 4px;
        border-radius: 50%;
        background: $color-accent;
        flex-shrink: 0;
        margin-top: 0.42em;
      }
    }

    &--modern {
      background: transparent;

      .features__grid {
        gap: 1rem;
        background: transparent;
        border: none;
      }

      .features__category {
        border: 1px solid var(--modern-border);
        border-radius: var(--modern-radius);
        background: var(--modern-surface-glass);
        box-shadow: var(--modern-shadow);
        padding: var(--modern-panel-padding);
      }

      .features__cat-title {
        font-family: var(--modern-font-body);
        font-size: 0.72rem;
        color: var(--modern-muted);
        border-bottom-color: rgba(148, 163, 184, 0.2);
      }

      .features__item {
        padding: 0.7rem 0;
        color: var(--modern-text);
        border-bottom-color: rgba(148, 163, 184, 0.14);

        &::before {
          width: 6px;
          height: 6px;
          background: rgba(15, 23, 42, 0.2);
          margin-top: 0.5em;
        }
      }
    }

    &--bold {
      background: transparent;

      .features__header h2 {
        font-size: clamp(2.1rem, 3.6vw, 3rem);
      }

      .features__grid {
        gap: 1rem;
        background: transparent;
        border: none;
        border-radius: 0;
      }

      .features__category {
        border: var(--bold-border-width) solid var(--bold-border);
        border-radius: var(--bold-radius);
        background: var(--bold-surface);
        box-shadow: var(--bold-shadow);
        padding: var(--bold-panel-padding);
      }

      .features__cat-title {
        font-family: var(--bold-font-heading);
        font-size: 0.74rem;
        color: var(--bold-accent);
        border-bottom: var(--bold-border-width) solid var(--bold-border);
      }

      .features__item {
        border-bottom-color: rgba(21, 21, 21, 0.16);
        color: var(--bold-text);
        font-weight: 500;

        &::before {
          width: 7px;
          height: 7px;
          border-radius: 0;
          background: var(--bold-text);
        }
      }
    }

    &--lifestyle {
      background: transparent;

      .features__grid {
        gap: 1rem;
        background: transparent;
        border: none;
      }

      .features__category {
        border: 1px solid var(--lifestyle-border);
        border-radius: var(--lifestyle-radius);
        background: var(--lifestyle-surface);
        box-shadow: var(--lifestyle-shadow);
        padding: calc(var(--lifestyle-panel-padding) - 0.1rem);
      }

      .features__cat-title {
        font-family: var(--lifestyle-font-body);
        font-size: 0.68rem;
        color: var(--lifestyle-muted);
        border-bottom-color: rgba(104, 90, 72, 0.12);
      }

      .features__item {
        border-bottom-color: rgba(104, 90, 72, 0.1);
        color: var(--lifestyle-text);

        &::before {
          width: 6px;
          height: 6px;
          background: var(--lifestyle-accent);
          opacity: 0.72;
        }
      }
    }
  }
</style>

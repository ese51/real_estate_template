---
import type { PropertyData } from '../types/property';

interface Props {
  property: PropertyData;
}

const { property } = Astro.props;
const { description, address, stats, price_display } = property;

const quickFacts = [
  { label: 'Style', value: stats.style },
  { label: 'Year Built', value: stats.year_built },
  { label: 'Living Area', value: `${stats.sqft.toLocaleString()} sq ft` },
  { label: 'Lot Size', value: stats.lot_size },
  { label: 'Bedrooms', value: stats.beds },
  { label: 'Bathrooms', value: stats.baths },
  { label: 'Garage', value: stats.garage },
].filter((fact) => fact.value !== undefined && fact.value !== null && fact.value !== '');
---

<section class="about section" id="about" aria-label="About this property">
  <div class="container">
    <div class="about__layout">

      <div class="about__text">
        <span class="section-label">About this Home</span>
        <h2>{address.street}</h2>
        <div class="divider"></div>
        <div class="about__description" set:html={description} />
      </div>

      <aside class="about__aside">
        <div class="about__card">
          <div class="about__card-header">
            <span class="about__card-label">Quick Facts</span>
            <span class="about__card-price">{price_display}</span>
          </div>

          <dl class="about__dl">
            {quickFacts.map((fact) => (
              <div class="about__dl-row">
                <dt>{fact.label}</dt>
                <dd>{fact.value}</dd>
              </div>
            ))}
          </dl>

          <a href="#contact" class="about__card-cta">
            Inquire About This Property
          </a>
        </div>
      </aside>

    </div>
  </div>
</section>

<style lang="scss">
  @use '../styles/variables' as *;

  .about {
    background: $color-bg;

    &__layout {
      display: grid;
      grid-template-columns: 1fr 360px;
      gap: $space-2xl;
      align-items: start;

      @media (max-width: $bp-lg) {
        grid-template-columns: 1fr;
        gap: $space-lg;
      }
    }

    h2 {
      margin-top: 0.5rem;
      font-size: clamp(1.8rem, 3vw, 2.6rem);
    }

    &__description {
      font-size: 1.05rem;
      line-height: 1.85;
      color: $color-text;
      max-width: 680px;

      :global(p + p) {
        margin-top: 1.4rem;
      }
    }

    // Aside card
    &__card {
      background: $color-primary;
      border-radius: 2px;
      overflow: hidden;
      position: sticky;
      top: 150px; // clears header + sticky strip
      box-shadow: 0 8px 40px rgba(0, 0, 0, 0.18);
    }

    &__card-header {
      padding: 1.5rem 1.75rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
    }

    &__card-label {
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: $color-accent;
    }

    &__card-price {
      font-family: $font-serif;
      font-size: 1.7rem;
      font-weight: 400;
      color: #fff;
    }

    &__dl {
      padding: 0.5rem 0;
    }

    &__dl-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.75rem 1.75rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);

      &:last-child {
        border-bottom: none;
      }

      dt {
        font-size: 0.78rem;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.45);
        letter-spacing: 0.04em;
      }

      dd {
        font-size: 0.88rem;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.85);
        text-align: right;
      }
    }

    &__card-cta {
      display: block;
      margin: 0;
      padding: 1.1rem 1.75rem;
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      text-align: center;
      color: $color-primary;
      background: $color-accent;
      transition: background $transition-fast;

      &:hover {
        background: #fff;
      }
    }
  }
</style>

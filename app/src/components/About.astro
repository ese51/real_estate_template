---
import type { PropertyData } from '../types/property';
import type { SiteTemplateId } from '../templates/site';

interface Props {
  property: PropertyData;
  variant?: SiteTemplateId;
}

const { property, variant = 'classic' } = Astro.props;
const { description, address, stats, price_display } = property;

const quickFacts = [
  { label: 'Style', value: stats.style },
  { label: 'Year Built', value: stats.year_built },
  { label: 'Living Area', value: `${stats.sqft.toLocaleString()} sq ft` },
  { label: 'Lot Size', value: stats.lot_size },
  { label: 'Bedrooms', value: stats.beds },
  { label: 'Bathrooms', value: stats.baths },
  { label: 'Garage', value: stats.garage },
].filter((fact) => fact.value !== undefined && fact.value !== null && fact.value !== '');
---

<section class:list={['about section', variant === 'modern' && 'about--modern', variant === 'bold' && 'about--bold', variant === 'lifestyle' && 'about--lifestyle']} id="about" aria-label="About this property">
  <div class="container">
    <div class="about__layout">

      <div class="about__text">
        <span class="section-label">About this Home</span>
        <h2>{variant === 'modern' ? 'Designed for daily living' : variant === 'lifestyle' ? 'A home shaped around how life unfolds' : address.street}</h2>
        <div class="divider"></div>
        <div class="about__description" set:html={description} />
      </div>

      <aside class="about__aside">
        <div class="about__card">
          <div class="about__card-header">
            <span class="about__card-label">Quick Facts</span>
            <span class="about__card-price">{price_display}</span>
          </div>

          <dl class="about__dl">
            {quickFacts.map((fact) => (
              <div class="about__dl-row">
                <dt>{fact.label}</dt>
                <dd>{fact.value}</dd>
              </div>
            ))}
          </dl>

          <a href="#contact" class="about__card-cta">
            Inquire About This Property
          </a>
        </div>
      </aside>

    </div>
  </div>
</section>

<style lang="scss">
  @use '../styles/variables' as *;

  .about {
    background: $color-bg;

    &__layout {
      display: grid;
      grid-template-columns: 1fr 360px;
      gap: $space-2xl;
      align-items: start;

      @media (max-width: $bp-lg) {
        grid-template-columns: 1fr;
        gap: $space-lg;
      }
    }

    h2 {
      margin-top: 0.5rem;
      font-size: clamp(1.8rem, 3vw, 2.6rem);
    }

    &__description {
      font-size: 1.05rem;
      line-height: 1.85;
      color: $color-text;
      max-width: 680px;

      :global(p + p) {
        margin-top: 1.4rem;
      }
    }

    // Aside card
    &__card {
      background: $color-primary;
      border-radius: 2px;
      overflow: hidden;
      position: sticky;
      top: 150px; // clears header + sticky strip
      box-shadow: 0 8px 40px rgba(0, 0, 0, 0.18);
    }

    &__card-header {
      padding: 1.5rem 1.75rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
    }

    &__card-label {
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: $color-accent;
    }

    &__card-price {
      font-family: $font-serif;
      font-size: 1.7rem;
      font-weight: 400;
      color: #fff;
    }

    &__dl {
      padding: 0.5rem 0;
    }

    &__dl-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.75rem 1.75rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);

      &:last-child {
        border-bottom: none;
      }

      dt {
        font-size: 0.78rem;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.45);
        letter-spacing: 0.04em;
      }

      dd {
        font-size: 0.88rem;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.85);
        text-align: right;
      }
    }

    &__card-cta {
      display: block;
      margin: 0;
      padding: 1.1rem 1.75rem;
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      text-align: center;
      color: $color-primary;
      background: $color-accent;
      transition: background $transition-fast;

      &:hover {
        background: #fff;
      }
    }

    &--modern {
      background: transparent;

      .about__layout {
        gap: 1.5rem;
        grid-template-columns: minmax(0, 1.15fr) 360px;

        @media (max-width: $bp-lg) {
          grid-template-columns: 1fr;
        }
      }

      .about__text,
      .about__card {
        border: 1px solid var(--modern-border);
        border-radius: var(--modern-radius);
        background: var(--modern-surface-glass);
        box-shadow: var(--modern-shadow);
      }

      .about__text {
        padding: var(--modern-panel-padding);
      }

      h2 {
        font-size: clamp(1.9rem, 3vw, 2.8rem);
      }

      .about__description {
        max-width: none;
        font-size: 1rem;
        line-height: 1.8;
        color: var(--modern-muted);
      }

      .about__card {
        position: sticky;
        top: 118px;
        padding: 1.2rem;
      }

      .about__card-header {
        padding: 0 0 1rem;
        border-bottom: 1px solid rgba(148, 163, 184, 0.2);
      }

      .about__card-label {
        color: var(--modern-muted);
      }

      .about__card-price {
        color: var(--modern-text);
        font-family: var(--modern-font-heading);
        font-size: 1.85rem;
      }

      .about__dl {
        padding: 0.5rem 0;
      }

      .about__dl-row {
        padding: 0.85rem 0;
        border-bottom-color: rgba(148, 163, 184, 0.18);

        dt {
          color: var(--modern-muted);
        }

        dd {
          color: var(--modern-text);
        }
      }

      .about__card-cta {
        margin-top: 0.6rem;
        border-radius: var(--modern-button-radius);
        background: var(--modern-accent);
        color: #fff;

        &:hover {
          background: #1e293b;
        }
      }
    }

    &--bold {
      background: transparent;

      .about__layout {
        gap: 1rem;
        grid-template-columns: minmax(0, 1.2fr) 340px;

        @media (max-width: $bp-lg) {
          grid-template-columns: 1fr;
        }
      }

      .about__text,
      .about__card {
        border: var(--bold-border-width) solid var(--bold-border);
        border-radius: var(--bold-radius);
        background: var(--bold-surface);
        box-shadow: var(--bold-shadow);
      }

      .about__text {
        padding: var(--bold-panel-padding);
      }

      h2 {
        font-size: clamp(2rem, 3.6vw, 3rem);
        text-transform: uppercase;
      }

      .about__description {
        max-width: none;
        font-size: 1rem;
        line-height: 1.78;

        :global(p + p) {
          margin-top: 1.2rem;
        }
      }

      .about__card {
        position: sticky;
        top: 110px;
        padding: 1rem;
      }

      .about__card-header {
        padding: 0 0 0.9rem;
        border-bottom: var(--bold-border-width) solid var(--bold-border);
      }

      .about__card-label {
        color: var(--bold-accent);
      }

      .about__card-price {
        color: var(--bold-text);
        font-family: var(--bold-font-heading);
      }

      .about__dl-row {
        padding: 0.85rem 0;
        border-bottom-color: rgba(21, 21, 21, 0.16);

        dt {
          color: var(--bold-muted);
        }

        dd {
          color: var(--bold-text);
        }
      }

      .about__card-cta {
        margin-top: 0.55rem;
        border-radius: var(--bold-radius);
        border: var(--bold-border-width) solid var(--bold-border);
        background: var(--bold-accent);
        color: #fff;
        box-shadow: 4px 4px 0 var(--bold-border);

        &:hover {
          background: #1e42b8;
        }
      }
    }

    &--lifestyle {
      background: transparent;

      .about__layout {
        gap: 1.5rem;
        grid-template-columns: minmax(0, 1.15fr) 360px;

        @media (max-width: $bp-lg) {
          grid-template-columns: 1fr;
        }
      }

      .about__text,
      .about__card {
        border: 1px solid var(--lifestyle-border);
        border-radius: var(--lifestyle-radius);
        background: var(--lifestyle-surface);
        box-shadow: var(--lifestyle-shadow);
      }

      .about__text {
        padding: var(--lifestyle-panel-padding);
      }

      h2 {
        font-size: clamp(2rem, 3.2vw, 3rem);
      }

      .about__description {
        max-width: none;
        font-size: 1.02rem;
        line-height: 1.86;
        color: var(--lifestyle-muted);
      }

      .about__card {
        top: 118px;
        padding: 1.2rem;
      }

      .about__card-header {
        padding: 0 0 1rem;
        border-bottom-color: rgba(104, 90, 72, 0.12);
      }

      .about__card-label {
        color: var(--lifestyle-muted);
      }

      .about__card-price {
        color: var(--lifestyle-text);
        font-family: var(--lifestyle-font-heading);
        font-weight: 600;
      }

      .about__dl-row {
        padding: 0.88rem 0;
        border-bottom-color: rgba(104, 90, 72, 0.1);

        dt {
          color: var(--lifestyle-muted);
        }

        dd {
          color: var(--lifestyle-text);
        }
      }

      .about__card-cta {
        margin-top: 0.6rem;
        border-radius: var(--lifestyle-button-radius);
        background: var(--lifestyle-accent);
        color: #fff;

        &:hover {
          background: #5e7568;
        }
      }
    }
  }
</style>

---
import type { PropertyData } from '../types/property';
import type { SiteTemplateId } from '../templates/site';

interface Props {
  property: PropertyData;
  variant?: SiteTemplateId;
}

const { property, variant = 'classic' } = Astro.props;
const { schools } = property;
---

{schools && schools.length > 0 && (
  <section class:list={['schools section section--mid', variant === 'modern' && 'schools--modern', variant === 'bold' && 'schools--bold', variant === 'lifestyle' && 'schools--lifestyle']} id="schools" aria-label="Nearby schools">
    <div class="container">
      <span class="section-label">Education</span>
      <h2>{variant === 'modern' ? 'Schools near the property' : variant === 'lifestyle' ? 'Schools that support daily life' : 'Nearby Schools'}</h2>
      <div class="divider"></div>

      <div class="schools__grid">
        {schools.map(school => (
          <div class="schools__card">
            <div class="schools__card-top">
              <span class="schools__level">{school.level}</span>
              {school.rating && (
                <div class="schools__rating">
                  <span class="schools__rating-num">{school.rating}</span>
                  <span class="schools__rating-den">/10</span>
                </div>
              )}
            </div>
            <h3 class="schools__name">{school.name}</h3>
            <p class="schools__district">{school.district}</p>
            {school.distance && (
              <p class="schools__distance">{school.distance} from property</p>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>
)}

<style lang="scss">
  @use '../styles/variables' as *;

  .schools {
    h2 {
      margin-top: 0.5rem;
      font-size: clamp(1.8rem, 3vw, 2.6rem);
    }

    &__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: $space-md;
      margin-top: $space-lg;

      @media (max-width: $bp-lg) {
        grid-template-columns: repeat(2, 1fr);
      }

      @media (max-width: $bp-sm) {
        grid-template-columns: 1fr;
      }
    }

    &__card {
      background: #fff;
      border: 1px solid $color-border;
      border-radius: 2px;
      padding: 1.75rem;
      transition: box-shadow $transition-base, transform $transition-base;

      &:hover {
        box-shadow: $shadow-md;
        transform: translateY(-2px);
      }
    }

    &__card-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 1rem;
    }

    &__level {
      font-size: 0.62rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #fff;
      background: $color-primary;
      padding: 0.28rem 0.7rem;
      border-radius: 2px;
    }

    &__rating {
      display: flex;
      align-items: baseline;
      gap: 0.05rem;
    }

    &__rating-num {
      font-family: $font-serif;
      font-size: 1.6rem;
      font-weight: 400;
      color: $color-accent;
      line-height: 1;
    }

    &__rating-den {
      font-size: 0.75rem;
      color: $color-text-muted;
      font-weight: 500;
    }

    &__name {
      font-family: $font-serif;
      font-size: 1.15rem;
      font-weight: 500;
      color: $color-primary;
      margin-bottom: 0.3rem;
      line-height: 1.3;
    }

    &__district {
      font-size: 0.8rem;
      color: $color-text-muted;
      margin-bottom: 0.5rem;
    }

    &__distance {
      font-size: 0.8rem;
      color: $color-accent;
      font-weight: 500;
    }

    &--modern {
      background: transparent;

      .schools__card {
        border: 1px solid var(--modern-border);
        border-radius: var(--modern-radius);
        padding: var(--modern-panel-padding);
        box-shadow: var(--modern-shadow);
      }

      .schools__level {
        border-radius: 999px;
        background: rgba(15, 23, 42, 0.08);
        color: var(--modern-text);
      }

      .schools__rating-num {
        font-family: var(--modern-font-heading);
        color: var(--modern-text);
      }

      .schools__rating-den,
      .schools__district {
        color: var(--modern-muted);
      }

      .schools__name {
        font-family: var(--modern-font-heading);
        color: var(--modern-text);
      }

      .schools__distance {
        color: #334155;
      }
    }

    &--bold {
      background: transparent;

      .schools__card {
        border: var(--bold-border-width) solid var(--bold-border);
        border-radius: var(--bold-radius);
        padding: var(--bold-panel-padding);
        box-shadow: var(--bold-shadow);
      }

      .schools__level {
        border-radius: var(--bold-radius);
        background: var(--bold-text);
        color: #fff;
      }

      .schools__rating-num,
      .schools__name {
        font-family: var(--bold-font-heading);
        color: var(--bold-text);
      }

      .schools__rating-den,
      .schools__district {
        color: var(--bold-muted);
      }

      .schools__distance {
        color: var(--bold-accent);
      }
    }

    &--lifestyle {
      background: transparent;

      .schools__card {
        border: 1px solid var(--lifestyle-border);
        border-radius: var(--lifestyle-radius);
        padding: calc(var(--lifestyle-panel-padding) - 0.1rem);
        background: var(--lifestyle-surface);
        box-shadow: var(--lifestyle-shadow);
      }

      .schools__level {
        border-radius: 999px;
        background: var(--lifestyle-accent-soft);
        color: var(--lifestyle-accent);
      }

      .schools__rating-num {
        font-family: var(--lifestyle-font-heading);
        color: var(--lifestyle-text);
      }

      .schools__rating-den,
      .schools__district {
        color: var(--lifestyle-muted);
      }

      .schools__name {
        font-family: var(--lifestyle-font-heading);
        color: var(--lifestyle-text);
        font-weight: 600;
      }

      .schools__distance {
        color: var(--lifestyle-accent);
      }
    }
  }
</style>

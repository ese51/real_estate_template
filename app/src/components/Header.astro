---
import type { PropertyData } from '../types/property';
import type { SiteTemplateId } from '../templates/site';

interface Props {
  property: PropertyData;
  variant?: SiteTemplateId;
}

const { property, variant = 'classic' } = Astro.props;
const { address, schedule_showing, floor_plans, schools } = property;

const navLinks = variant === 'modern' || variant === 'bold' || variant === 'lifestyle'
  ? [
      { href: '#gallery', label: 'Gallery' },
      { href: '#summary', label: 'Overview' },
      { href: '#features', label: 'Features' },
      ...(schools && schools.length > 0 ? [{ href: '#schools', label: 'Schools' }] : []),
      { href: '#location', label: 'Location' },
      { href: '#contact', label: 'Contact' },
    ]
  : [
      { href: '#about', label: 'About' },
      { href: '#features', label: 'Features' },
      { href: '#floor-plans', label: 'Plans' },
      { href: '#location', label: 'Location' },
      { href: '#contact', label: 'Contact' },
    ];
---

<header class:list={['header', variant === 'modern' && 'header--modern', variant === 'bold' && 'header--bold', variant === 'lifestyle' && 'header--lifestyle']} id="header">
  <div class="header__inner container">

    <a href="#hero" class="header__brand" aria-label="Back to top">
      <span class="header__street">{address.street}</span>
      <span class="header__city">{address.city}, {address.state}</span>
    </a>

    <!-- Desktop nav — hidden on mobile via CSS -->
    <nav class="header__nav" aria-label="Page sections">
      {navLinks.map((link) => (
        <a href={link.href} class="header__link">{link.label}</a>
      ))}
      {schedule_showing.enabled && (
        <a href="#schedule" class="header__cta">Schedule a Tour</a>
      )}
    </nav>

    <!-- Mobile right-side controls: CTA + hamburger -->
    <div class="header__mobile-cta">
      {schedule_showing.enabled && (
        <a href="#schedule" class="header__cta">Tour</a>
      )}
      <button
        class="header__hamburger"
        id="header-hamburger"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="header-mobile-menu"
      >
        <span class="header__ham-bar"></span>
        <span class="header__ham-bar"></span>
        <span class="header__ham-bar"></span>
      </button>
    </div>

  </div>

  <!-- Mobile dropdown menu — sits below the header bar, inside the fixed element -->
  <nav
    class="header__mobile-menu"
    id="header-mobile-menu"
    aria-label="Mobile navigation"
  >
    <div class="container">
      {navLinks.map((link) => (
        <a href={link.href} class="header__mobile-link">{link.label}</a>
      ))}
      {schedule_showing.enabled && (
        <a href="#schedule" class="header__mobile-link header__mobile-link--accent">
          Schedule a Tour
        </a>
      )}
    </div>
  </nav>

</header>

<script>
  const header    = document.getElementById('header')!;
  const hamburger = document.getElementById('header-hamburger') as HTMLButtonElement;
  const menu      = document.getElementById('header-mobile-menu')!;

  // ── Scroll state ────────────────────────────────────────────────────────────
  const THRESHOLD = 60;
  const syncScrollClass = () => {
    header.classList.toggle('is-scrolled', window.scrollY > THRESHOLD);
  };
  window.addEventListener('scroll', syncScrollClass, { passive: true });
  syncScrollClass();

  // ── Hamburger toggle ────────────────────────────────────────────────────────
  if (hamburger && menu) {
    function openMenu() {
      menu.classList.add('is-open');
      hamburger.classList.add('is-open');
      hamburger.setAttribute('aria-expanded', 'true');
      // Keep header solid while menu is open regardless of scroll position
      header.classList.add('is-scrolled');
    }

    function closeMenu() {
      menu.classList.remove('is-open');
      hamburger.classList.remove('is-open');
      hamburger.setAttribute('aria-expanded', 'false');
      // Restore scroll-driven header state
      syncScrollClass();
    }

    hamburger.addEventListener('click', () => {
      menu.classList.contains('is-open') ? closeMenu() : openMenu();
    });

    // Close on any link click — menu closes, then native anchor scroll takes over
    menu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', closeMenu);
    });

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeMenu();
    });

    // Close on click outside the header
    document.addEventListener('click', (e) => {
      if (!header.contains(e.target as Node)) closeMenu();
    });
  }
</script>

<style lang="scss">
  @use '../styles/variables' as *;

  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;

    // ── Transparent state (floating over hero) ──
    background: transparent;
    border-bottom: 1px solid transparent;
    transition:
      background  0.4s ease,
      border-color 0.4s ease,
      box-shadow  0.4s ease;

    // ── Scrolled state (solid, readable) ──
    &.is-scrolled {
      background: rgba(12, 12, 22, 0.96);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      border-bottom: 1px solid rgba(255, 255, 255, 0.07);
      box-shadow: 0 2px 24px rgba(0, 0, 0, 0.28);
    }

    &__inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 68px;
    }

    // ── Brand (address) ──
    &__brand {
      display: flex;
      flex-direction: column;
      gap: 2px;
      line-height: 1;
      flex-shrink: 0;
    }

    &__street {
      font-family: $font-serif;
      font-size: 1rem;
      font-weight: 400;
      color: #fff;
      letter-spacing: 0.01em;
    }

    &__city {
      font-size: 0.62rem;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.42);
    }

    // ── Desktop nav links ──
    &__nav {
      display: flex;
      align-items: center;
      gap: 1.75rem;

      @media (max-width: $bp-lg) {
        display: none;
      }
    }

    &__link {
      font-size: 0.75rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.62);
      transition: color 0.2s ease;

      &:hover {
        color: #fff;
      }
    }

    // ── CTA button (used in both desktop nav and mobile bar) ──
    &__cta {
      display: inline-block;
      padding: 0.52rem 1.25rem;
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: $color-primary;
      background: $color-accent;
      border-radius: 2px;
      transition: background 0.2s ease, transform 0.15s ease;

      &:hover {
        background: #fff;
        transform: translateY(-1px);
      }
    }

    &--modern {
      // Hero phase: transparent — house is the surface
      background: transparent;

      // Scrolled: restore full modern chrome
      &.is-scrolled {
        background: rgba(248, 250, 252, 0.92);
        border-bottom: 1px solid rgba(148, 163, 184, 0.2);
        box-shadow: 0 10px 30px rgba(15, 23, 42, 0.06);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);

        .header__street { color: #0f172a; }
        .header__city { color: #64748b; }
        .header__link { color: #475569; &:hover { color: #0f172a; } }
        .header__cta {
          background: var(--modern-accent);
          color: #fff;
          border-color: transparent;
          box-shadow: 0 10px 22px rgba(15, 23, 42, 0.1);
          &:hover { background: #1e293b; }
        }
        .header__hamburger {
          border-color: rgba(148, 163, 184, 0.34);
          &:hover { border-color: rgba(100, 116, 139, 0.6); }
        }
        .header__ham-bar { background: #0f172a; }
      }

      .header__inner { height: 76px; }

      .header__street {
        font-family: var(--modern-font-heading);
        font-size: 0.98rem;
        font-weight: 700;
        color: #fff;
        letter-spacing: -0.02em;
      }

      .header__city {
        font-size: 0.66rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        color: rgba(255, 255, 255, 0.5);
      }

      .header__nav { gap: 1.2rem; }

      .header__link {
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        color: rgba(255, 255, 255, 0.68);
        &:hover { color: #fff; }
      }

      .header__cta {
        padding: 0.52rem 1rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.12);
        color: rgba(255, 255, 255, 0.9);
        border: 1px solid rgba(255, 255, 255, 0.22);
        box-shadow: none;
        backdrop-filter: blur(8px);
        &:hover { background: rgba(255, 255, 255, 0.2); }
      }

      .header__hamburger {
        border-radius: 999px;
        border-color: rgba(255, 255, 255, 0.24);
        &:hover { border-color: rgba(255, 255, 255, 0.42); }
      }

      .header__ham-bar { background: rgba(255, 255, 255, 0.82); }

      .header__mobile-menu {
        background: rgba(248, 250, 252, 0.96);
        border-top: 1px solid rgba(148, 163, 184, 0.2);
        box-shadow: 0 20px 40px rgba(15, 23, 42, 0.08);
      }

      .header__mobile-link {
        color: #334155;
        font-weight: 600;
        &:hover { color: #0f172a; }
      }

      .header__mobile-link--accent { color: #0f172a; }
    }

    &--bold {
      // Hero phase: transparent — full bold personality appears on scroll
      background: transparent;
      border-bottom-color: transparent;

      // Scrolled: snap to full bold chrome
      &.is-scrolled {
        background: rgba(249, 244, 236, 0.98);
        border-bottom: var(--bold-border-width) solid var(--bold-border);

        .header__street { color: var(--bold-text); }
        .header__city { color: var(--bold-muted); }
        .header__link { color: var(--bold-text); &:hover { color: var(--bold-accent); } }
        .header__cta {
          background: var(--bold-accent);
          color: #fff;
          border: var(--bold-border-width) solid var(--bold-border);
          box-shadow: 4px 4px 0 var(--bold-border);
          &:hover { background: #1e42b8; transform: translate(-1px, -1px); }
        }
        .header__hamburger {
          border: var(--bold-border-width) solid var(--bold-border);
          background: var(--bold-surface);
        }
        .header__ham-bar { background: var(--bold-text); }
      }

      .header__inner { height: 74px; }

      .header__street {
        font-family: var(--bold-font-heading);
        font-size: 1rem;
        font-weight: 700;
        color: #fff;
        text-transform: uppercase;
        letter-spacing: -0.03em;
      }

      .header__city {
        color: rgba(255, 255, 255, 0.5);
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.18em;
      }

      .header__nav { gap: 1rem; }

      .header__link {
        color: rgba(255, 255, 255, 0.68);
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.14em;
        &:hover { color: #fff; }
      }

      .header__cta {
        border-radius: var(--bold-radius);
        border: var(--bold-border-width) solid rgba(255, 255, 255, 0.28);
        background: rgba(255, 255, 255, 0.1);
        color: #fff;
        box-shadow: none;
        &:hover { background: rgba(255, 255, 255, 0.2); transform: none; }
      }

      .header__hamburger {
        border: var(--bold-border-width) solid rgba(255, 255, 255, 0.24);
        border-radius: var(--bold-radius);
        background: transparent;
      }

      .header__ham-bar { background: rgba(255, 255, 255, 0.82); }

      .header__mobile-menu {
        background: var(--bold-surface);
        border-top: var(--bold-border-width) solid var(--bold-border);
        box-shadow: 0 10px 0 rgba(21, 21, 21, 0.04);
      }

      .header__mobile-link {
        color: var(--bold-text);
        font-weight: 700;
        &:hover { color: var(--bold-accent); }
      }

      .header__mobile-link--accent { color: var(--bold-accent); }
    }

    &--lifestyle {
      // Hero phase: transparent — warm editorial chrome appears on scroll
      background: transparent;
      border-bottom-color: transparent;

      // Scrolled: restore full lifestyle warmth
      &.is-scrolled {
        background: rgba(255, 250, 244, 0.94);
        border-bottom: 1px solid var(--lifestyle-border);
        box-shadow: 0 10px 30px rgba(53, 43, 31, 0.06);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);

        .header__street { font-family: var(--lifestyle-font-heading); color: var(--lifestyle-text); font-weight: 600; }
        .header__city { color: var(--lifestyle-muted); }
        .header__link { color: var(--lifestyle-muted); &:hover { color: var(--lifestyle-text); } }
        .header__cta {
          background: var(--lifestyle-accent);
          color: #fff;
          border-color: transparent;
          box-shadow: 0 10px 24px rgba(111, 133, 119, 0.2);
          &:hover { background: #5e7568; }
        }
        .header__hamburger {
          border-radius: 999px;
          border-color: var(--lifestyle-border-strong);
          background: rgba(255, 250, 244, 0.9);
        }
        .header__ham-bar { background: var(--lifestyle-text); }
      }

      .header__inner { height: 78px; }

      .header__street {
        font-family: var(--lifestyle-font-heading);
        font-size: 1rem;
        font-weight: 600;
        color: #fff;
        letter-spacing: -0.02em;
      }

      .header__city {
        font-size: 0.66rem;
        font-weight: 600;
        letter-spacing: 0.14em;
        color: rgba(255, 255, 255, 0.5);
      }

      .header__nav { gap: 1.1rem; }

      .header__link {
        font-size: 0.73rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        color: rgba(255, 255, 255, 0.65);
        &:hover { color: #fff; }
      }

      .header__cta {
        padding: 0.62rem 1.1rem;
        border-radius: var(--lifestyle-button-radius);
        background: rgba(255, 255, 255, 0.12);
        color: rgba(255, 255, 255, 0.9);
        border: 1px solid rgba(255, 255, 255, 0.22);
        box-shadow: none;
        backdrop-filter: blur(8px);
        &:hover { background: rgba(255, 255, 255, 0.2); }
      }

      .header__hamburger {
        border-radius: 999px;
        border-color: rgba(255, 255, 255, 0.24);
        background: transparent;
        &:hover { border-color: rgba(255, 255, 255, 0.42); }
      }

      .header__ham-bar { background: rgba(255, 255, 255, 0.82); }

      .header__mobile-menu {
        background: rgba(255, 250, 244, 0.96);
        border-top: 1px solid var(--lifestyle-border);
        box-shadow: 0 18px 36px rgba(53, 43, 31, 0.08);
      }

      .header__mobile-link {
        color: var(--lifestyle-muted);
        font-weight: 600;
        &:hover { color: var(--lifestyle-text); }
      }

      .header__mobile-link--accent { color: var(--lifestyle-text); }
    }

    // ── Mobile right-side controls: Tour CTA + hamburger ──
    &__mobile-cta {
      display: none;

      @media (max-width: $bp-lg) {
        display: flex;
        align-items: center;
        gap: 0.75rem;
      }
    }

    // ── Hamburger button ──
    &__hamburger {
      display: none; // hidden on desktop

      @media (max-width: $bp-lg) {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 5px;
        width: 2.25rem;
        height: 2.25rem;
        background: none;
        border: 1px solid rgba(255, 255, 255, 0.16);
        border-radius: 2px;
        cursor: pointer;
        padding: 0;
        flex-shrink: 0;
        transition: border-color 0.2s ease;

        &:hover {
          border-color: rgba(255, 255, 255, 0.38);
        }
      }
    }

    &__ham-bar {
      display: block;
      width: 16px;
      height: 2px;
      background: rgba(255, 255, 255, 0.82);
      border-radius: 1px;
      transition: transform 0.25s ease, opacity 0.2s ease;

      // Animate into X when open
      .header__hamburger.is-open &:nth-child(1) {
        transform: translateY(7px) rotate(45deg);
      }
      .header__hamburger.is-open &:nth-child(2) {
        opacity: 0;
        transform: scaleX(0);
      }
      .header__hamburger.is-open &:nth-child(3) {
        transform: translateY(-7px) rotate(-45deg);
      }
    }

    // ── Mobile dropdown menu ──
    &__mobile-menu {
      // Hidden by default — controlled via max-height + opacity transition
      overflow: hidden;
      max-height: 0;
      opacity: 0;
      pointer-events: none;
      transition: max-height 0.28s ease, opacity 0.22s ease;

      // Always solid background — the header may be transparent while
      // the menu is open, so the menu brings its own backdrop
      background: rgba(10, 10, 20, 0.97);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      border-bottom: 1px solid rgba(255, 255, 255, 0.07);

      // Completely absent on desktop — hamburger can't be clicked there
      // but this is a belt-and-suspenders guard
      @media (min-width: #{$bp-lg + 1}) {
        display: none;
      }

      &.is-open {
        max-height: 400px; // generous upper bound — only actual content height is used
        opacity: 1;
        pointer-events: auto;
      }

      .container {
        display: flex;
        flex-direction: column;
        padding-top: 0.5rem;
        padding-bottom: 1rem;
      }
    }

    &__mobile-link {
      display: block;
      padding: 0.85rem 0;
      font-size: 0.8rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.62);
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      transition: color 0.18s ease;

      &:last-child {
        border-bottom: none;
      }

      &:hover {
        color: #fff;
      }

      // Schedule a Tour — accent treatment
      &--accent {
        color: $color-accent;
        margin-top: 0.4rem;
        border-top: 1px solid rgba(255, 255, 255, 0.06);
        border-bottom: none;
        padding-top: 1rem;

        &:hover {
          color: #fff;
        }
      }
    }
  }
</style>

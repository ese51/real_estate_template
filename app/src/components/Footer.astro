---
import type { PropertyData } from '../types/property';
import type { SiteTemplateId } from '../templates/site';

interface Props {
  property: PropertyData;
  variant?: SiteTemplateId;
}

const { property, variant = 'classic' } = Astro.props;
const { address, price_display, status, agent, schedule_showing, schools, floor_plans } = property;
const year = new Date().getFullYear();
const brokerage = agent.brokerage?.trim();
const legalMessage = brokerage
  ? `© ${year} Hive Nova. This is a demo website and is not affiliated with ${brokerage}.`
  : `© ${year} Hive Nova. This is a demo website created for marketing purposes.`;
const footerLinks = [
  { href: '#about', label: 'About the Home' },
  { href: '#features', label: 'Features & Finishes' },
  ...(floor_plans && floor_plans.length > 0 ? [{ href: '#floor-plans', label: 'Floor Plans' }] : []),
  ...(schools && schools.length > 0 ? [{ href: '#schools', label: 'Nearby Schools' }] : []),
  { href: '#location', label: 'Location' },
  { href: '#contact', label: 'Contact' },
];
---

<footer class:list={['footer', variant === 'modern' && 'footer--modern', variant === 'bold' && 'footer--bold', variant === 'lifestyle' && 'footer--lifestyle']} aria-label="Site footer">

  <div class="footer__main">
    <div class="container">
      <div class="footer__grid">

        <!-- Column 1: Property identity -->
        <div class="footer__col footer__col--identity">
          <p class="footer__status-pill">{status}</p>
          <h2 class="footer__address">{address.street}</h2>
          <p class="footer__city">{address.city}, {address.state} {address.zip}</p>
          <p class="footer__price">{price_display}</p>
          {schedule_showing.enabled && (
            <a href="#schedule" class="footer__cta">Schedule a Tour</a>
          )}
        </div>

        <!-- Column 2: Navigation -->
        <nav class="footer__col footer__col--nav" aria-label="Footer links">
          <span class="footer__col-label">On This Page</span>
          <ul>
            {footerLinks.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </nav>

        <!-- Column 3: Agent -->
        <div class="footer__col footer__col--agent">
          <span class="footer__col-label">Listing Agent</span>
          <p class="footer__agent-name">{agent.name}</p>
          {agent.brokerage && <p class="footer__agent-brokerage">{agent.brokerage}</p>}
          <div class="footer__agent-contacts">
            <a href={`tel:${agent.phone.replace(/\D/g, '')}`}>{agent.phone}</a>
            <a href={`mailto:${agent.email}`}>{agent.email}</a>
          </div>
          {agent.license && <p class="footer__license">Lic. #{agent.license}</p>}
        </div>

      </div>
    </div>
  </div>

  <div class="footer__legal">
    <div class="container">
      <p class="footer__legal-copy">{legalMessage}</p>
    </div>
  </div>

</footer>

<style lang="scss">
  @use '../styles/variables' as *;
  @use 'sass:color';

  .footer {
    &__main {
      background: $color-primary;
      padding: $space-xl $space-md;
    }

    &__grid {
      display: grid;
      grid-template-columns: 1.5fr 1fr 1fr;
      gap: $space-xl;

      @media (max-width: $bp-lg) {
        grid-template-columns: 1fr 1fr;
        gap: $space-lg;
      }

      @media (max-width: $bp-sm) {
        grid-template-columns: 1fr;
      }
    }

    &__col {
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    &__col-label {
      font-size: 0.62rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.3);
      margin-bottom: 1.25rem;
    }

    // Identity column
    &__status-pill {
      display: inline-block;
      width: fit-content;
      font-size: 0.62rem;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: $color-primary;
      background: $color-accent;
      padding: 0.25rem 0.65rem;
      border-radius: 2px;
      margin-bottom: 1rem;
    }

    &__address {
      font-family: $font-serif;
      font-size: clamp(1.4rem, 3vw, 2rem);
      font-weight: 400;
      color: #fff;
      line-height: 1.2;
      margin-bottom: 0.4rem;
    }

    &__city {
      font-size: 0.78rem;
      color: rgba(255, 255, 255, 0.4);
      letter-spacing: 0.08em;
      margin-bottom: 0.75rem;
    }

    &__price {
      font-family: $font-serif;
      font-size: 1.3rem;
      color: $color-accent;
      margin-bottom: 1.5rem;
    }

    &__cta {
      display: inline-block;
      width: fit-content;
      padding: 0.75rem 1.5rem;
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: $color-primary;
      background: $color-accent;
      border-radius: 2px;
      transition: background $transition-fast;

      &:hover {
        background: #fff;
      }
    }

    // Nav column
    &__col--nav {
      ul {
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
      }

      a {
        font-size: 0.85rem;
        color: rgba(255, 255, 255, 0.5);
        transition: color $transition-fast;
        letter-spacing: 0.02em;

        &:hover {
          color: rgba(255, 255, 255, 0.9);
        }
      }
    }

    // Agent column
    &__agent-name {
      font-family: $font-serif;
      font-size: 1.15rem;
      color: #fff;
      margin-bottom: 0.2rem;
    }

    &__agent-brokerage {
      font-size: 0.78rem;
      color: $color-accent;
      font-weight: 500;
      margin-bottom: 1rem;
    }

    &__agent-contacts {
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
      margin-bottom: 0.75rem;

      a {
        font-size: 0.85rem;
        color: rgba(255, 255, 255, 0.55);
        transition: color $transition-fast;

        &:hover {
          color: $color-accent;
        }
      }
    }

    &__license {
      font-size: 0.7rem;
      color: rgba(255, 255, 255, 0.2);
    }

    // Legal strip
    &__legal {
      background: color.adjust($color-primary, $lightness: -4%);
      padding: 1.25rem $space-md;

      .container {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: $space-lg;
        flex-wrap: wrap;
      }
    }

    &__legal-copy {
      font-size: 0.7rem;
      color: rgba(255, 255, 255, 0.34);
      line-height: 1.7;
      max-width: 680px;
    }

    &--modern {
      .footer__main {
        background: transparent;
        padding-top: 1rem;
      }

      .footer__grid {
        border: 1px solid var(--modern-border);
        border-radius: var(--modern-radius);
        background: var(--modern-surface-glass);
        box-shadow: var(--modern-shadow);
        padding: var(--modern-panel-padding);
      }

      .footer__col-label,
      .footer__city,
      .footer__license,
      .footer__copy,
      .footer__disclaimer {
        color: var(--modern-muted);
      }

      .footer__status-pill {
        border-radius: 999px;
        background: rgba(15, 23, 42, 0.08);
        color: var(--modern-text);
      }

      .footer__address,
      .footer__agent-name,
      .footer__price {
        font-family: var(--modern-font-heading);
        color: var(--modern-text);
      }

      .footer__cta {
        border-radius: var(--modern-button-radius);
        background: var(--modern-accent);
        color: #fff;

        &:hover {
          background: #1e293b;
        }
      }

      .footer__col--nav a,
      .footer__agent-contacts a,
      .footer__agent-brokerage {
        color: #334155;

        &:hover {
          color: var(--modern-text);
        }
      }

      .footer__legal {
        background: transparent;
        padding-top: 1rem;
        padding-bottom: 2rem;
      }

      .footer__legal-copy {
        color: var(--modern-muted);
      }
    }

    &--bold {
      .footer__main {
        background: transparent;
        padding-top: 1rem;
      }

      .footer__grid {
        border: var(--bold-border-width) solid var(--bold-border);
        border-radius: var(--bold-radius);
        background: var(--bold-surface);
        box-shadow: var(--bold-shadow-lg);
        padding: var(--bold-panel-padding);
      }

      .footer__col-label,
      .footer__city,
      .footer__license,
      .footer__copy,
      .footer__disclaimer {
        color: var(--bold-muted);
      }

      .footer__status-pill {
        border-radius: var(--bold-radius);
        background: var(--bold-accent);
        color: #fff;
      }

      .footer__address,
      .footer__agent-name,
      .footer__price {
        font-family: var(--bold-font-heading);
        color: var(--bold-text);
      }

      .footer__cta {
        border-radius: var(--bold-radius);
        border: var(--bold-border-width) solid var(--bold-border);
        background: var(--bold-accent);
        color: #fff;
        box-shadow: 4px 4px 0 var(--bold-border);

        &:hover {
          background: #1e42b8;
          transform: translate(-1px, -1px);
        }
      }

      .footer__col--nav a,
      .footer__agent-contacts a,
      .footer__agent-brokerage {
        color: var(--bold-text);

        &:hover {
          color: var(--bold-accent);
        }
      }

      .footer__legal {
        background: transparent;
        padding-top: 1rem;
        padding-bottom: 2rem;
      }

      .footer__legal-copy {
        color: rgba(15, 23, 42, 0.62);
      }
    }

    &--lifestyle {
      .footer__main {
        background: transparent;
        padding-top: 0;
      }

      .footer__grid {
        border: 1px solid var(--lifestyle-border);
        border-radius: calc(var(--lifestyle-radius) + 2px);
        background: var(--lifestyle-surface);
        box-shadow: var(--lifestyle-shadow-lg);
        padding: clamp(1.5rem, 3vw, 2.5rem);
      }

      .footer__col-label,
      .footer__city,
      .footer__license,
      .footer__copy,
      .footer__disclaimer {
        color: var(--lifestyle-muted);
      }

      .footer__status-pill {
        border-radius: 999px;
        background: var(--lifestyle-accent);
        color: #fff;
      }

      .footer__address,
      .footer__agent-name,
      .footer__price {
        font-family: var(--lifestyle-font-heading);
        color: var(--lifestyle-text);
        font-weight: 600;
      }

      .footer__cta {
        border-radius: var(--lifestyle-button-radius);
        background: var(--lifestyle-accent);
        color: #fff;
        box-shadow: 0 12px 24px rgba(111, 133, 119, 0.16);

        &:hover {
          background: #5e7568;
        }
      }

      .footer__col--nav a,
      .footer__agent-contacts a,
      .footer__agent-brokerage {
        color: var(--lifestyle-muted);

        &:hover {
          color: var(--lifestyle-text);
        }
      }

      .footer__price,
      .footer__agent-brokerage {
        color: var(--lifestyle-accent);
      }

      .footer__legal {
        background: transparent;
        padding-top: 1rem;
        padding-bottom: 2rem;
      }

      .footer__legal-copy {
        color: rgba(80, 73, 65, 0.7);
      }
    }
  }
</style>

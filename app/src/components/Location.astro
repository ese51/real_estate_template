---
import type { PropertyData } from '../types/property';
import type { SiteTemplateId } from '../templates/site';

interface Props {
  property: PropertyData;
  variant?: SiteTemplateId;
}

const { property, variant = 'classic' } = Astro.props;
const { location, address } = property;

const STATE_NAMES: Record<string, string> = {
  MD: 'Maryland',
  VA: 'Virginia',
  DC: 'District of Columbia',
  PA: 'Pennsylvania',
  NY: 'New York',
  FL: 'Florida',
  CA: 'California',
  TX: 'Texas',
};

const stateName = STATE_NAMES[address.state] ?? address.state;
const situatedIn = `Situated in ${address.city}, ${stateName}`;

const mapsUrl = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(address.full)}`;
const embedUrl = `https://maps.google.com/maps?q=${encodeURIComponent(address.full)}&output=embed&z=15`;
---

<section class:list={['location section', variant === 'modern' && 'location--modern', variant === 'bold' && 'location--bold', variant === 'lifestyle' && 'location--lifestyle']} id="location" aria-label="Location">
  <div class="location__inner">
    <div class="container">
      <div class="location__layout">

        <div class="location__text">
          <span class="section-label">Location</span>
          <h2>{variant === 'lifestyle' ? `Life in ${address.city}` : situatedIn}</h2>
          <div class="divider"></div>
          <p class="location__address">{address.full}</p>

          <ul class="location__highlights">
            {location.highlights.map(item => (
              <li class="location__highlight">
                <span class="location__arrow" aria-hidden="true">→</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>

          <a
            href={mapsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="location__map-cta"
          >
            View on Google Maps
          </a>
        </div>

        <div class="location__map-panel">
          <iframe
            src={embedUrl}
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen={false}
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title={`Map showing ${address.full}`}
            scrolling="no"
          ></iframe>
        </div>

      </div>
    </div>
  </div>
</section>

<style lang="scss">
  @use '../styles/variables' as *;

  .location {
    &__inner {
      background: $color-primary;
      padding: $section-padding-y $space-md;
    }

    &__layout {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: $space-2xl;
      align-items: center;

      @media (max-width: $bp-lg) {
        grid-template-columns: 1fr;
        gap: $space-lg;
      }
    }

    h2 {
      color: #fff;
      margin-top: 0.5rem;
      font-size: clamp(1.8rem, 3vw, 2.6rem);
    }

    .divider {
      background: rgba($color-accent, 0.7);
    }

    &__address {
      font-size: 0.85rem;
      color: rgba(255, 255, 255, 0.4);
      letter-spacing: 0.04em;
      margin-top: -0.5rem;
      margin-bottom: 2rem;
    }

    &__highlights {
      display: flex;
      flex-direction: column;
      gap: 0.85rem;
      margin-bottom: $space-md;
    }

    &__highlight {
      display: flex;
      align-items: baseline;
      gap: 0.85rem;
      font-size: 0.95rem;
      color: rgba(255, 255, 255, 0.72);
      line-height: 1.5;
    }

    &__arrow {
      color: $color-accent;
      font-size: 0.85rem;
      flex-shrink: 0;
    }

    &__map-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: $color-accent;
      border-bottom: 1px solid rgba($color-accent, 0.4);
      padding-bottom: 2px;
      transition: color $transition-fast, border-color $transition-fast;

      &:hover {
        color: #fff;
        border-color: rgba(255, 255, 255, 0.4);
      }
    }

    &__map-panel {
      height: 420px;
      border-radius: 6px;
      overflow: hidden;
      border: 1px solid rgba(255, 255, 255, 0.08);

      iframe {
        display: block;
        width: 100%;
        height: 100%;
        border: 0;
      }

      @media (max-width: $bp-lg) {
        height: 320px;
      }
    }

    &--modern {
      .location__inner {
        background: transparent;
        padding: 0;
      }

      .location__layout {
        gap: 1.5rem;
      }

      .location__text,
      .location__map-panel {
        border: 1px solid var(--modern-border);
        border-radius: var(--modern-radius);
        background: var(--modern-surface-glass);
        box-shadow: var(--modern-shadow);
      }

      .location__text {
        padding: var(--modern-panel-padding);
      }

      h2 {
        color: var(--modern-text);
      }

      .divider {
        background: rgba(100, 116, 139, 0.28);
      }

      .location__address,
      .location__highlight {
        color: var(--modern-muted);
      }

      .location__arrow {
        color: var(--modern-text);
      }

      .location__map-cta {
        color: var(--modern-text);
        border-bottom-color: rgba(15, 23, 42, 0.16);

        &:hover {
          color: #1e293b;
          border-color: rgba(15, 23, 42, 0.28);
        }
      }

      .location__map-panel {
        border-radius: var(--modern-radius);
        border-color: var(--modern-border);
        overflow: hidden;
      }
    }

    &--bold {
      .location__inner {
        background: transparent;
        padding: 0;
      }

      .location__layout {
        gap: 1rem;
      }

      .location__text,
      .location__map-panel {
        border: var(--bold-border-width) solid var(--bold-border);
        border-radius: var(--bold-radius);
        background: var(--bold-surface);
        box-shadow: var(--bold-shadow);
      }

      .location__text {
        padding: var(--bold-panel-padding);
      }

      h2 {
        color: var(--bold-text);
        text-transform: uppercase;
      }

      .divider {
        background: var(--bold-accent);
      }

      .location__address,
      .location__highlight {
        color: var(--bold-text);
      }

      .location__arrow,
      .location__map-cta {
        color: var(--bold-accent);
      }

      .location__map-cta {
        border-bottom-color: var(--bold-accent);

        &:hover {
          color: var(--bold-text);
          border-color: var(--bold-text);
        }
      }
    }

    &--lifestyle {
      .location__inner {
        background: transparent;
        padding: 0;
      }

      .location__layout {
        gap: 1.5rem;
      }

      .location__text,
      .location__map-panel {
        border: 1px solid var(--lifestyle-border);
        border-radius: var(--lifestyle-radius);
        background: var(--lifestyle-surface);
        box-shadow: var(--lifestyle-shadow);
      }

      .location__text {
        padding: var(--lifestyle-panel-padding);
      }

      h2 {
        color: var(--lifestyle-text);
      }

      .divider {
        background: rgba(111, 133, 119, 0.32);
      }

      .location__address,
      .location__highlight {
        color: var(--lifestyle-muted);
      }

      .location__arrow {
        color: var(--lifestyle-accent);
      }

      .location__map-cta {
        color: var(--lifestyle-accent);
        border-bottom-color: rgba(111, 133, 119, 0.24);

        &:hover {
          color: var(--lifestyle-text);
          border-color: rgba(104, 90, 72, 0.26);
        }
      }
    }
  }
</style>

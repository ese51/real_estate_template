---
// Conditional section — only renders when gallery.images has entries
import type { PropertyData } from '../types/property';
import type { SiteTemplateId } from '../templates/site';

interface Props {
  property: PropertyData;
  variant?: SiteTemplateId;
}

const { property, variant = 'classic' } = Astro.props;
const { gallery, address } = property;

const images = gallery.images ?? [];
const featured = images[0];
const preview  = images.slice(1, 9); // up to 8 shown initially
const overflow = images.slice(9);    // revealed on click
const totalRemaining = overflow.length;
---

{images.length > 0 && (
  <section class:list={['gallery', variant === 'modern' && 'gallery--modern', variant === 'bold' && 'gallery--bold', variant === 'lifestyle' && 'gallery--lifestyle']} id="gallery" aria-label="Property gallery">

    <!-- Featured image: full width, tall -->
    {featured && (
      <div
        class="gallery__featured"
        data-lb-src={featured.url}
        data-lb-alt={featured.alt || `${address.street} — featured`}
        data-lb-group="gallery"
      >
        <img
          src={featured.url}
          alt={featured.alt || `${address.street} — featured`}
          loading="eager"
        />
        <div class="gallery__featured-overlay">
          <span class="gallery__count">
            {images.length} {images.length === 1 ? 'Photo' : 'Photos'}
          </span>
        </div>
      </div>
    )}

    <!-- Grid of remaining images -->
    {preview.length > 0 && (
      <div class="gallery__grid container" id="gallery-grid">
        {preview.map((image, i) => (
          <div
            class="gallery__item"
            data-lb-src={image.url}
            data-lb-alt={image.alt || `${address.street} — photo ${i + 2}`}
            data-lb-group="gallery"
          >
            <img
              src={image.url}
              alt={image.alt || `${address.street} — photo ${i + 2}`}
              loading="lazy"
            />
            {image.caption && (
              <span class="gallery__caption">{image.caption}</span>
            )}
          </div>
        ))}

        {totalRemaining > 0 && (
          <button
            class="gallery__more-tile"
            id="gallery-more-btn"
            aria-label={`Show ${totalRemaining} more photos`}
          >
            <span class="gallery__more-num">+{totalRemaining}</span>
            <span class="gallery__more-label">More Photos</span>
          </button>
        )}

        {overflow.map((image, i) => (
          <div
            class="gallery__item gallery__item--hidden"
            data-lb-src={image.url}
            data-lb-alt={image.alt || `${address.street} — photo ${i + 10}`}
            data-lb-group="gallery"
          >
            <img
              src={image.url}
              alt={image.alt || `${address.street} — photo ${i + 10}`}
              loading="lazy"
            />
            {image.caption && (
              <span class="gallery__caption">{image.caption}</span>
            )}
          </div>
        ))}
      </div>
    )}

    <!-- Section label below the imagery -->
    <div class="gallery__footer container">
      <span class="section-label">Photo Tour</span>
      <h2 class="gallery__heading">{variant === 'modern' ? 'A clean look at every detail' : variant === 'bold' ? 'Framed views of the home' : variant === 'lifestyle' ? 'A curated look at the spaces that shape daily life' : address.street}</h2>
    </div>

  </section>
)}

<!--
  Script is intentionally outside the conditional so Astro processes it
  as a module script (TypeScript compiled, deferred). The btn check makes
  it safe when the gallery section is absent.
-->
<script>
  const btn = document.getElementById('gallery-more-btn');
  if (btn) {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.gallery__item--hidden')
        .forEach(el => el.classList.remove('gallery__item--hidden'));
      btn.remove();
    });
  }
</script>

<style lang="scss">
  @use '../styles/variables' as *;

  .gallery {
    background: $color-primary;
    padding-bottom: $space-xl;

    &__featured {
      position: relative;
      width: 100%;
      height: 70vh;
      min-height: 480px;
      overflow: hidden;
      cursor: pointer;

      img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: transform $transition-slow;
        pointer-events: none;
      }

      &:hover img {
        transform: scale(1.03);
      }

      // Mobile: tie height to viewport width so the container stays
      // landscape-ish. At 390px width: ~290px tall (4:3 ratio) vs the
      // current 480px min, so ~75% of image width is visible instead
      // of ~40%. Override min-height so it doesn't fight the rule.
      @media (max-width: $bp-sm) {
        height: 75vw;
        min-height: 180px;
      }
    }

    &__featured-overlay {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 2rem;
      background: linear-gradient(to top, rgba(0,0,0,0.5), transparent);
      display: flex;
      justify-content: flex-end;
      pointer-events: none;
    }

    &__count {
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.65);
      padding: 0.4rem 0.85rem;
      background: rgba(0, 0, 0, 0.35);
      border: 1px solid rgba(255, 255, 255, 0.15);
      border-radius: 2px;
      backdrop-filter: blur(4px);
    }

    &__grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 4px;
      padding-top: 4px;

      @media (max-width: $bp-lg) {
        grid-template-columns: repeat(3, 1fr);
      }

      @media (max-width: $bp-sm) {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    &__item {
      position: relative;
      aspect-ratio: 4 / 3;
      overflow: hidden;
      cursor: pointer;
      background: rgba(255, 255, 255, 0.04);

      img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform $transition-slow, opacity $transition-base;
        pointer-events: none;
      }

      &:hover img {
        transform: scale(1.06);
        opacity: 0.85;
      }

      // On mobile, anchor images toward the upper portion so rooflines
      // and ceiling details aren't cut when a portrait-ish image appears
      // in the landscape 4:3 grid cell.
      @media (max-width: $bp-sm) {
        img {
          object-position: center 20%;
        }
      }
    }

    &__caption {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 0.6rem 0.85rem;
      background: linear-gradient(transparent, rgba(0,0,0,0.6));
      color: rgba(255,255,255,0.85);
      font-size: 0.75rem;
      letter-spacing: 0.04em;
      transform: translateY(100%);
      transition: transform $transition-base;
      pointer-events: none;

      .gallery__item:hover & {
        transform: translateY(0);
      }
    }

    &__item--hidden {
      display: none;
    }

    &__more-tile {
      width: 100%;
      aspect-ratio: 4 / 3;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.3rem;
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(255, 255, 255, 0.08);
      cursor: pointer;
      transition: background $transition-fast;

      &:hover {
        background: rgba(255, 255, 255, 0.08);
      }
    }

    &__more-num {
      font-family: $font-serif;
      font-size: 2rem;
      color: rgba(255, 255, 255, 0.6);
      line-height: 1;
    }

    &__more-label {
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.35);
    }

    &__footer {
      padding-top: $space-lg;

      h2 {
        color: rgba(255, 255, 255, 0.9);
        margin-top: 0.5rem;
        font-size: clamp(1.8rem, 3vw, 2.4rem);
      }
    }

    &--modern {
      background: transparent;
      padding-bottom: 0;

      .gallery__featured {
        max-width: $container-max;
        margin: 0 auto;
        height: clamp(360px, 60vw, 760px);
        min-height: 360px;
        border-radius: var(--modern-radius);
        border: 1px solid var(--modern-border);
        box-shadow: var(--modern-shadow-lg);

        @media (max-width: $bp-md) {
          height: 70vw;
          border-radius: var(--modern-radius-md);
        }
      }

      .gallery__featured-overlay {
        justify-content: space-between;
        align-items: end;
        padding: 1.5rem;
        background: linear-gradient(to top, rgba(15, 23, 42, 0.38), rgba(15, 23, 42, 0.08), transparent);
      }

      .gallery__count {
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.14);
        color: #fff;
        border-color: rgba(255, 255, 255, 0.2);
      }

      .gallery__grid {
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1rem;
        padding-top: 1.25rem;

        @media (max-width: $bp-lg) {
          grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        @media (max-width: $bp-sm) {
          grid-template-columns: repeat(2, minmax(0, 1fr));
          gap: 0.8rem;
        }
      }

      .gallery__item,
      .gallery__more-tile {
        border: 1px solid var(--modern-border);
        border-radius: var(--modern-radius-md);
        background: var(--modern-surface-glass);
        box-shadow: var(--modern-shadow);
      }

      .gallery__caption {
        transform: translateY(0);
        padding: 1rem 1rem 0.85rem;
        background: linear-gradient(transparent, rgba(15, 23, 42, 0.7));
      }

      .gallery__more-tile {
        color: var(--modern-text);

        &:hover {
          background: var(--modern-surface);
        }
      }

      .gallery__more-num {
        color: var(--modern-text);
      }

      .gallery__more-label {
        color: var(--modern-muted);
      }

      .gallery__footer {
        padding-top: 1.5rem;

        h2 {
          color: var(--modern-text);
          margin-top: 0.7rem;
          font-size: clamp(1.9rem, 3vw, 2.6rem);
        }
      }
    }

    &--bold {
      background: transparent;
      padding-bottom: 0;

      .gallery__featured {
        max-width: $container-max;
        margin: 0 auto;
        height: clamp(360px, 58vw, 720px);
        min-height: 360px;
        border: 3px solid var(--bold-border);
        border-radius: var(--bold-radius);
        box-shadow: var(--bold-shadow-lg);
      }

      .gallery__featured-overlay {
        padding: 1.2rem;
        justify-content: flex-start;
        background: linear-gradient(to top, rgba(21, 21, 21, 0.56), rgba(21, 21, 21, 0.08), transparent);
      }

      .gallery__count {
        border-radius: var(--bold-radius);
        border: var(--bold-border-width) solid #fff;
        background: var(--bold-accent);
        color: #fff;
      }

      .gallery__grid {
        gap: 0.9rem;
        padding-top: 1.1rem;

        @media (max-width: $bp-sm) {
          gap: 0.7rem;
        }
      }

      .gallery__item,
      .gallery__more-tile {
        border: var(--bold-border-width) solid var(--bold-border);
        border-radius: var(--bold-radius);
        background: #fff;
        box-shadow: var(--bold-shadow);
      }

      .gallery__caption {
        transform: translateY(0);
        padding: 0.85rem 0.95rem 0.8rem;
        background: linear-gradient(transparent, rgba(21, 21, 21, 0.82));
        font-weight: 600;
      }

      .gallery__more-tile {
        &:hover {
          background: var(--bold-surface-alt);
        }
      }

      .gallery__more-num {
        font-family: var(--bold-font-heading);
        color: var(--bold-text);
      }

      .gallery__more-label {
        color: var(--bold-accent);
        font-weight: 800;
      }

      .gallery__footer {
        padding-top: 1.45rem;

        h2 {
          color: var(--bold-text);
          margin-top: 0.7rem;
          font-size: clamp(2rem, 3.2vw, 2.9rem);
          text-transform: uppercase;
        }
      }
    }

    &--lifestyle {
      background: transparent;
      padding-bottom: 0;

      .gallery__featured {
        max-width: $container-max;
        margin: 0 auto;
        height: clamp(400px, 62vw, 760px);
        min-height: 400px;
        border-radius: calc(var(--lifestyle-radius) + 4px);
        border: 1px solid var(--lifestyle-border);
        box-shadow: var(--lifestyle-shadow-lg);
      }

      .gallery__featured-overlay {
        justify-content: flex-start;
        align-items: end;
        padding: 1.6rem;
        background: linear-gradient(to top, rgba(47, 41, 36, 0.42), rgba(47, 41, 36, 0.08), transparent);
      }

      .gallery__count {
        border-radius: 999px;
        background: rgba(255, 250, 244, 0.16);
        color: #fff;
        border-color: rgba(255, 255, 255, 0.18);
      }

      .gallery__grid {
        gap: 1rem;
        padding-top: 1.25rem;

        @media (max-width: $bp-sm) {
          gap: 0.8rem;
        }
      }

      .gallery__item,
      .gallery__more-tile {
        border: 1px solid var(--lifestyle-border);
        border-radius: var(--lifestyle-radius-md);
        background: var(--lifestyle-surface);
        box-shadow: var(--lifestyle-shadow);
      }

      .gallery__caption {
        transform: translateY(0);
        padding: 0.95rem 1rem 0.85rem;
        background: linear-gradient(transparent, rgba(47, 41, 36, 0.72));
      }

      .gallery__more-tile {
        &:hover {
          background: var(--lifestyle-surface-strong);
        }
      }

      .gallery__more-num {
        font-family: var(--lifestyle-font-heading);
        color: var(--lifestyle-text);
      }

      .gallery__more-label {
        color: var(--lifestyle-muted);
      }

      .gallery__footer {
        padding-top: 1.6rem;

        h2 {
          color: var(--lifestyle-text);
          margin-top: 0.7rem;
          font-size: clamp(2rem, 3.2vw, 2.95rem);
          max-width: 26ch;
        }
      }
    }
  }
</style>

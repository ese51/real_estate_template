---
/**
 * [slug].astro — Dynamic multi-listing route
 *
 * Generates one static page per JSON file found in src/data/properties/.
 * The route slug comes from property.meta.slug, not the filename.
 *
 * To add a new listing:
 *   1. Add src/data/properties/[any-name].json with meta.slug set
 *   2. Add app/public/images/[slug]/ with the listing's photos
 *   3. Run the build — the page is generated automatically.
 */

import type { PropertyData } from '../types/property';
import PropertyLayout from '../layouts/PropertyLayout.astro';
import PropertyPage from '../components/PropertyPage.astro';
import { resolveSiteTemplateId } from '../templates/site';

export async function getStaticPaths() {
  const modules = import.meta.glob<{ default: PropertyData }>(
    '../data/properties/*.json',
    { eager: true }
  );

  const entries = Object.entries(modules);

  if (entries.length === 0) {
    throw new Error(
      'No property JSON files found in src/data/properties/. ' +
      'Add at least one listing JSON before building.'
    );
  }

  return entries.map(([sourcePath, mod]) => {
    const property = mod.default;
    if (!property?.meta?.slug) {
      throw new Error(
        `Property JSON missing required meta.slug for static route generation: ${sourcePath}`
      );
    }

    // Slug comes from the data, not the filename — stays correct
    // even if the file is renamed.
    return { params: { slug: property.meta.slug }, props: { property } };
  });
}

interface Props {
  property: PropertyData;
}

const { property } = Astro.props;
const templateId = resolveSiteTemplateId(property);
const hasPersistentCta = (templateId === 'modern' || templateId === 'bold' || templateId === 'lifestyle')
  && (property.schedule_showing.enabled || Boolean(property.agent.phone) || Boolean(property.agent.email));
---

<PropertyLayout property={property} templateId={templateId} hasPersistentCta={hasPersistentCta}>
  <PropertyPage property={property} templateId={templateId} />
</PropertyLayout>

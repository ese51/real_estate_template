---
/**
 * [slug].astro — Dynamic multi-listing route
 *
 * Generates one static page per JSON file found in src/data/properties/.
 * The route slug comes from property.meta.slug, not the filename.
 *
 * To add a new listing:
 *   1. Add src/data/properties/[any-name].json with meta.slug set
 *   2. Add app/public/images/[slug]/ with the listing's photos
 *   3. Run the build — the page is generated automatically.
 */

import type { PropertyData } from '../types/property';
import PropertyLayout from '../layouts/PropertyLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Gallery from '../components/Gallery.astro';
import PropertySummary from '../components/PropertySummary.astro';
import About from '../components/About.astro';
import Features from '../components/Features.astro';
import Schools from '../components/Schools.astro';
import Location from '../components/Location.astro';
import FloorPlans from '../components/FloorPlans.astro';
import Contact from '../components/Contact.astro';
import ScheduleShowing from '../components/ScheduleShowing.astro';
import Footer from '../components/Footer.astro';
import Lightbox from '../components/Lightbox.astro';

export async function getStaticPaths() {
  const modules = import.meta.glob<{ default: PropertyData }>(
    '../data/properties/*.json',
    { eager: true }
  );

  const entries = Object.entries(modules);

  if (entries.length === 0) {
    throw new Error(
      'No property JSON files found in src/data/properties/. ' +
      'Add at least one listing JSON before building.'
    );
  }

  return entries.map(([sourcePath, mod]) => {
    const property = mod.default;
    if (!property?.meta?.slug) {
      throw new Error(
        `Property JSON missing required meta.slug for static route generation: ${sourcePath}`
      );
    }

    // Slug comes from the data, not the filename — stays correct
    // even if the file is renamed.
    return { params: { slug: property.meta.slug }, props: { property } };
  });
}

interface Props {
  property: PropertyData;
}

const { property } = Astro.props;
---

<PropertyLayout property={property}>
  <Header property={property} />
  <main>
    <Hero property={property} />
    <PropertySummary property={property} />
    <About property={property} />
    <Location property={property} />
    <Gallery property={property} />
    <Features property={property} />
    <Schools property={property} />
    <FloorPlans property={property} />
    <Contact property={property} />
    <ScheduleShowing property={property} />
  </main>
  <Footer property={property} />
  <Lightbox />
</PropertyLayout>

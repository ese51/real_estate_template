---
// Root route — intentionally neutral.
// Individual listing demos are only accessible via direct slug URL.
// Nothing here links to or reveals any listing.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hive Nova</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Inter', sans-serif;
        background: #1a1a2e;
        color: rgba(255, 255, 255, 0.45);
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100svh;
        -webkit-font-smoothing: antialiased;
      }

      .wrap {
        text-align: center;
      }

      .wordmark {
        font-size: 1rem;
        font-weight: 600;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: #b8975a;
      }

      .tagline {
        margin-top: 0.75rem;
        font-size: 0.78rem;
        letter-spacing: 0.06em;
        color: rgba(255, 255, 255, 0.28);
      }
    </style>
  </head>
  <body>
    <div class="wrap">
      <p class="wordmark">Hive Nova</p>
      <p class="tagline">Property marketing built for how agents work.</p>
    </div>
  </body>
</html>

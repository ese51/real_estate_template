---
const demoListing = {
  address: '1615 N Wakefield St',
  city: 'Arlington, VA',
  price: '$2,845,000',
};

const templateDemos = [
  {
    id: 'classic',
    name: 'Classic',
    href: '/1615nwakefield',
    accent: '#7c6f5e',
    accentBg: 'rgba(124, 111, 94, 0.08)',
    what: 'Timeless luxury estate presentation with full-bleed hero, warm serif type, and traditional section flow.',
    when: [
      'Luxury single-family homes and historic estates',
      'Traditional architecture or legacy properties',
      'Buyers who expect a polished, conventional experience',
    ],
    cta: false,
  },
  {
    id: 'modern',
    name: 'Modern',
    href: '/1615nwakefield-modern',
    accent: '#2e6ba6',
    accentBg: 'rgba(46, 107, 166, 0.07)',
    what: 'Clean, product-page layout with strong stat hierarchy and a persistent contact CTA for conversion-focused listings.',
    when: [
      'Contemporary builds, condos, and new construction',
      'Tech-forward or younger buyers',
      'Agents who prioritize lead capture',
    ],
    cta: true,
  },
  {
    id: 'bold',
    name: 'Bold',
    href: '/1615nwakefield-bold',
    accent: '#c0392b',
    accentBg: 'rgba(192, 57, 43, 0.07)',
    what: 'High-contrast neubrutalist layout with heavy borders, stark typography, and a grid-forward visual structure.',
    when: [
      'Architecturally significant or design-forward homes',
      'Social-media-first campaigns that need to stand out',
      'Clients who want a distinctly non-generic presentation',
    ],
    cta: true,
  },
  {
    id: 'lifestyle',
    name: 'Lifestyle',
    href: '/1615nwakefield-lifestyle',
    accent: '#5a7a4e',
    accentBg: 'rgba(90, 122, 78, 0.07)',
    what: 'Warm editorial tone with neighborhood storytelling, rich descriptions, and a place-aware content structure.',
    when: [
      'Lifestyle relocations where community matters',
      'Buyers motivated by neighborhood experience',
      'Listings with strong outdoor, school, or area story',
    ],
    cta: true,
  },
];

const comparisonRows = [
  {
    label: 'Aesthetic',
    values: ['Traditional luxury', 'Clean / minimal', 'Neubrutalist', 'Warm editorial'],
  },
  {
    label: 'Typography',
    values: ['Serif-forward', 'Sans-serif', 'Heavy contrast', 'Mixed editorial'],
  },
  {
    label: 'Persistent CTA',
    values: [false, true, true, true],
  },
  {
    label: 'Best for',
    values: ['Estates & legacy', 'Condos & new builds', 'Design-forward', 'Lifestyle buyers'],
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hive Nova Template Demos</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Inter', sans-serif;
        background: #f5f1ea;
        color: #2f2924;
        min-height: 100svh;
        -webkit-font-smoothing: antialiased;
      }

      .wrap {
        width: min(1100px, calc(100% - 2.5rem));
        margin: 0 auto;
        padding: 4.5rem 0 5rem;
      }

      .wordmark {
        font-size: 0.88rem;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #6f8577;
      }

      .eyebrow {
        display: inline-block;
        margin-top: 1.5rem;
        padding: 0.38rem 0.72rem;
        border-radius: 999px;
        background: rgba(111, 133, 119, 0.12);
        color: #516459;
        font-size: 0.74rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      h1 {
        margin-top: 1rem;
        font-size: clamp(2.6rem, 5vw, 4.5rem);
        line-height: 0.96;
        letter-spacing: -0.04em;
      }

      .tagline {
        margin-top: 0.9rem;
        font-size: 1.1rem;
        line-height: 1.7;
        max-width: 42rem;
        color: #6f655c;
      }

      .lede {
        margin-top: 0.75rem;
        font-size: 0.98rem;
        color: #857a70;
      }

      /* ── Cards ── */

      .grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1rem;
        margin-top: 2.5rem;
      }

      .card {
        display: flex;
        flex-direction: column;
        gap: 0;
        border: 1px solid rgba(104, 90, 72, 0.14);
        border-radius: 20px;
        background: rgba(255, 250, 244, 0.9);
        box-shadow: 0 14px 28px rgba(53, 43, 31, 0.07);
        overflow: hidden;
      }

      .card__accent {
        height: 4px;
      }

      .card__body {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        padding: 1.4rem;
        flex: 1;
      }

      .card__header {
        display: flex;
        align-items: center;
        gap: 0.65rem;
      }

      .card__badge {
        display: inline-block;
        padding: 0.22rem 0.55rem;
        border-radius: 999px;
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.07em;
        text-transform: uppercase;
      }

      .card__name {
        font-size: 1.22rem;
        font-weight: 700;
        letter-spacing: -0.03em;
      }

      .card__what {
        font-size: 0.88rem;
        line-height: 1.6;
        color: #514840;
      }

      .card__when-label {
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.07em;
        text-transform: uppercase;
        color: #857a70;
        margin-bottom: 0.45rem;
      }

      .card__when-list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
      }

      .card__when-list li {
        font-size: 0.83rem;
        line-height: 1.5;
        color: #6f655c;
        padding-left: 1.1em;
        position: relative;
      }

      .card__when-list li::before {
        content: '→';
        position: absolute;
        left: 0;
        opacity: 0.45;
        font-size: 0.78rem;
      }

      .card__cta-note {
        font-size: 0.74rem;
        color: #857a70;
        margin-top: auto;
        padding-top: 0.25rem;
      }

      .card__cta-dot {
        display: inline-block;
        width: 7px;
        height: 7px;
        border-radius: 50%;
        margin-right: 0.35em;
        vertical-align: middle;
        position: relative;
        top: -1px;
      }

      .card__footer {
        padding: 0 1.4rem 1.4rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }

      .card__link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 44px;
        padding: 0.75rem 1rem;
        border-radius: 999px;
        color: #fff;
        font-size: 0.76rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        text-decoration: none;
        transition: opacity 0.15s ease;
      }

      .card__link:hover { opacity: 0.82; }

      .card__link--secondary {
        background: transparent;
        border: 1px solid rgba(104, 90, 72, 0.22);
        color: #514840;
        font-size: 0.72rem;
        min-height: 36px;
        padding: 0.5rem 1rem;
      }

      .card__link--secondary:hover { background: rgba(104, 90, 72, 0.06); opacity: 1; }

      /* ── Comparison table ── */

      .section-label {
        margin-top: 3rem;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #857a70;
      }

      .compare-wrap {
        margin-top: 0.75rem;
        border: 1px solid rgba(104, 90, 72, 0.14);
        border-radius: 18px;
        background: rgba(255, 250, 244, 0.8);
        overflow: hidden;
      }

      .compare-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.88rem;
      }

      .compare-table th,
      .compare-table td {
        padding: 0.8rem 1.1rem;
        text-align: left;
        vertical-align: middle;
      }

      .compare-table thead th {
        font-size: 0.76rem;
        font-weight: 700;
        letter-spacing: 0.07em;
        text-transform: uppercase;
        color: #857a70;
        background: rgba(245, 241, 234, 0.6);
        border-bottom: 1px solid rgba(104, 90, 72, 0.1);
      }

      .compare-table thead th:first-child { color: transparent; }

      .compare-table tbody tr + tr td {
        border-top: 1px solid rgba(104, 90, 72, 0.08);
      }

      .compare-table td:first-child {
        font-weight: 600;
        font-size: 0.82rem;
        color: #514840;
        white-space: nowrap;
      }

      .compare-table td.val { color: #6f655c; }

      .compare-table .pill {
        display: inline-block;
        padding: 0.18rem 0.55rem;
        border-radius: 999px;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.04em;
      }

      .pill--yes { background: rgba(90, 122, 78, 0.12); color: #3a5e30; }
      .pill--no  { background: rgba(104, 90, 72, 0.1);  color: #7a6e65; }

      /* ── Notes ── */

      .notes {
        margin-top: 2rem;
        padding: 1.1rem 1.4rem;
        border: 1px solid rgba(104, 90, 72, 0.12);
        border-radius: 14px;
        background: rgba(255, 250, 244, 0.6);
        color: #6f655c;
        font-size: 0.88rem;
        line-height: 1.7;
      }

      .notes code {
        font-family: 'SF Mono', 'Fira Code', monospace;
        font-size: 0.83em;
        background: rgba(104, 90, 72, 0.09);
        padding: 0.1em 0.35em;
        border-radius: 4px;
      }

      /* ── Responsive ── */

      @media (max-width: 1040px) {
        .grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .compare-wrap { overflow-x: auto; }
        .compare-table { min-width: 520px; }
      }

      @media (max-width: 640px) {
        .wrap {
          width: min(100% - 1.5rem, 1100px);
          padding-top: 3rem;
          padding-bottom: 3.5rem;
        }
        .grid { grid-template-columns: 1fr; }
      }
    </style>
  </head>
  <body>
    <div class="wrap">
      <p class="wordmark">Hive Nova</p>
      <span class="eyebrow">Internal Template Demo</span>
      <h1>One listing, four template presentations.</h1>
      <p class="tagline">
        Use this page for internal review, sales demos, and template selection conversations.
        Each card renders the same listing through a different visual template.
      </p>
      <p class="lede">{demoListing.address} &middot; {demoListing.city} &middot; {demoListing.price}</p>

      <div class="grid">
        {templateDemos.map((t) => (
          <article class="card">
            <div class="card__accent" style={`background:${t.accent}`} />
            <div class="card__body">
              <div class="card__header">
                <span class="card__name">{t.name}</span>
                <span
                  class="card__badge"
                  style={`background:${t.accentBg};color:${t.accent}`}
                >
                  {t.id}
                </span>
              </div>

              <p class="card__what">{t.what}</p>

              <div>
                <p class="card__when-label">When to use</p>
                <ul class="card__when-list">
                  {t.when.map((w) => <li>{w}</li>)}
                </ul>
              </div>

              <p class="card__cta-note">
                <span
                  class="card__cta-dot"
                  style={`background:${t.cta ? '#5a7a4e' : '#b0a89e'}`}
                />
                Persistent CTA: {t.cta ? 'Enabled' : 'Not included'}
              </p>
            </div>

            <div class="card__footer">
              <a class="card__link" href={t.href} style={`background:${t.accent}`}>
                Open Demo
              </a>
              <a class="card__link card__link--secondary" href={t.href} target="_blank" rel="noopener">
                Open in new tab
              </a>
            </div>
          </article>
        ))}
      </div>

      <!-- Comparison table -->
      <p class="section-label">At a glance</p>
      <div class="compare-wrap">
        <table class="compare-table">
          <thead>
            <tr>
              <th></th>
              {templateDemos.map((t) => (
                <th style={`color:${t.accent}`}>{t.name}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {comparisonRows.map((row) => (
              <tr>
                <td>{row.label}</td>
                {row.values.map((val) => (
                  <td class="val">
                    {typeof val === 'boolean' ? (
                      <span class={val ? 'pill pill--yes' : 'pill pill--no'}>
                        {val ? 'Yes' : 'No'}
                      </span>
                    ) : (
                      val
                    )}
                  </td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="notes">
        Template is selected via the <code>meta.template</code> field in the property JSON, or via the
        <code>site_template</code> field in builder input. No separate template schema or page contract exists.
        All four templates use the same section order and property data shape.
      </div>
    </div>
  </body>
</html>

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hive Nova — Real Estate Listing Sites</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Inter', sans-serif;
        background: #f5f1ea;
        color: #2f2924;
        min-height: 100svh;
        display: flex;
        align-items: center;
        justify-content: center;
        -webkit-font-smoothing: antialiased;
      }

      .card {
        width: min(480px, calc(100% - 3rem));
        padding: 2.5rem 2.75rem;
        background: rgba(255, 250, 244, 0.92);
        border: 1px solid rgba(104, 90, 72, 0.14);
        border-radius: 20px;
        box-shadow: 0 16px 40px rgba(53, 43, 31, 0.08);
      }

      .wordmark {
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #6f8577;
      }

      h1 {
        margin-top: 1.1rem;
        font-size: 1.55rem;
        font-weight: 700;
        letter-spacing: -0.03em;
        line-height: 1.2;
        color: #2f2924;
      }

      .divider {
        margin: 1.4rem 0;
        border: none;
        border-top: 1px solid rgba(104, 90, 72, 0.12);
      }

      .body {
        display: flex;
        flex-direction: column;
        gap: 0.65rem;
      }

      .body p {
        font-size: 0.92rem;
        line-height: 1.65;
        color: #6f655c;
      }
    </style>
  </head>
  <body>
    <div class="card">
      <p class="wordmark">Hive Nova</p>
      <h1>Real Estate Listing Sites</h1>
      <hr class="divider" />
      <div class="body">
        <p>This site hosts private property presentation pages and demo environments.</p>
        <p>Direct listing links are provided individually. No public listing index is available.</p>
      </div>
    </div>
  </body>
</html>
